<div class="news">
  {% if site.news != blank %}
    {% assign news_size = site.news | size %}
    <div
      class="table-responsive"
      {% if include.limit and page.announcements.limit and news_size > page.announcements.limit %}
        style="max-height: 60vh; overflow-y: auto"
      {% endif %}
    >
      <table class="table table-sm table-borderless">
        {% assign news_items = site.news | sort: 'date' | reverse %}
        {% for item in news_items limit: page.announcements.limit %}
          <tr>
            <th scope="row" style="width: 20%; white-space: nowrap">{{ item.date | date: '%b %-d, %Y' }}</th>
            <td>
              {% if item.inline %}
                {{ item.content | remove: '<p>' | remove: '</p>' | emojify }}
              {% else %}
                <a class="news-title" href="{{ item.url | relative_url }}">{{ item.title }}</a>
              {% endif %}
            </td>
          </tr>
        {% endfor %}
      </table>
    </div>
  {% else %}
    <p>No news so far...</p>
  {% endif %}
</div>
